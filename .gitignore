
# Sandbox — local experiments, not tracked
sandbox/

# === Model checkpoints & large files ===
*.pt
*.pth
*.safetensors
*.bin
*.gguf
*.pkl
checkpoints/
models/

# === Notebook artifacts (rollouts, SAC checkpoints, generated datasets) ===
# Exclude contents (not the dir itself) so negation can re-include subpaths.
notebooks/artifacts/*
# Exception: track SFT distillation datasets — small (~6 MB) and needed by Colab nb05
!notebooks/artifacts/sft_datasets
notebooks/artifacts/sft_datasets/*
!notebooks/artifacts/sft_datasets/*.jsonl

# === Experiment outputs ===
results/raw_data/
results/checkpoints/

# === Weights & Biases ===
wandb/

# === Python ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# === Jupyter ===
.ipynb_checkpoints/

# === Environment & secrets ===
.env
.env.local

# Environments
.venv/
.venv312/
venv/
env/

# === OS ===
.DS_Store
Thumbs.db

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === Data files (generated on the fly by CityLearn) ===
*.csv
*.h5
*.hdf5
# Exception: keep small config/example CSVs
!configs/*.csv
!data/examples/*.csv